{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://servercn.vercel.app/schema/registry.json",
  "title": "Servercn Registry Schema",
  "description": "Schema definition for the Servercn documentation and registry configuration file.",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "name", "homepage", "author", "items"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Schema reference URI.",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "description": "The name of the registry or project.",
      "minLength": 1
    },
    "homepage": {
      "type": "string",
      "description": "The public homepage URL of the project.",
      "format": "uri"
    },
    "author": {
      "type": "string",
      "description": "The author or maintainer of the registry.",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "description": "List of documentation entries and registry items.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/item"
      }
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "description": "Represents a single registry entry.",
      "additionalProperties": false,
      "required": ["slug", "title", "description", "type", "status", "docs"],
      "properties": {
        "slug": {
          "type": "string",
          "description": "Unique kebab-case identifier used for routing and registry referencing.",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "description": "Human-readable title of the registry entry.",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "description": "Detailed explanation of what this entry provides.",
          "minLength": 10
        },
        "type": {
          "type": "string",
          "description": "Defines the category of the registry entry.",
          "enum": [
            "guide",
            "contributing",
            "component",
            "blueprint",
            "foundation",
            "schema",
            "tooling"
          ]
        },
        "frameworks": {
          "type": "array",
          "description": "List of supported frameworks.",
          "items": {
            "type": "string",
            "enum": ["express", "nestjs"]
          }
        },
        "status": {
          "type": "string",
          "description": "Indicates the stability level of the entry.",
          "enum": ["stable", "beta", "experimental", "deprecated"]
        },
        "docs": {
          "type": "string",
          "description": "Relative documentation path starting with /docs/.",
          "pattern": "^/docs/[a-z0-9\\-/]+$"
        },
        "meta": {
          "$ref": "#/$defs/meta"
        }
      },
      "dependentSchemas": {
        "meta": {
          "properties": {
            "meta": {
              "dependentSchemas": {
                "databases": {
                  "properties": {
                    "type": {
                      "enum": ["schema", "blueprint"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "description": "Additional configuration metadata.",
      "additionalProperties": false,
      "properties": {
        "new": {
          "type": "boolean",
          "description": "Marks an entry as newly introduced.",
          "default": false
        },
        "databases": {
          "type": "array",
          "description": "List of supported database implementations.",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "slug"],
            "properties": {
              "label": {
                "type": "string",
                "description": "Human-readable database name.",
                "minLength": 1
              },
              "slug": {
                "type": "string",
                "description": "Unique kebab-case identifier for the database variant.",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              }
            }
          }
        }
      }
    }
  }
}

{
  "slug": "prettier",
  "templates": {
    "base": {
      "files": [
        {
          "type": "tooling",
          "path": ".prettierrc",
          "content": "{\r\n  \"singleQuote\": false,\r\n  \"semi\": true,\r\n  \"tabWidth\": 2,\r\n  \"trailingComma\": \"none\",\r\n  \"bracketSameLine\": true,\r\n  \"arrowParens\": \"avoid\",\r\n  \"endOfLine\": \"lf\"\r\n}\r\n"
        },
        {
          "type": "tooling",
          "path": ".prettierignore",
          "content": "dist\r\nnode_modules\r\ncoverage\r\n.env\r\n.env.*\r\n!.env.example\r\n"
        }
      ]
    }
  },
  "dependencies": {
    "runtime": [],
    "dev": [
      "prettier"
    ]
  }
}

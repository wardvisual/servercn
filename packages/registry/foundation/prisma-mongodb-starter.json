{
  "$schema": "https://servercn.vercel.app/schema/foundation.registry.json",
  "slug": "prisma-mongodb-starter",
  "runtimes": {
    "node": {
      "frameworks": {
        "express": {
          "templates": {
            "mvc": "prisma-mongodb-starter/mvc",
            "feature": "prisma-mongodb-starter/feature"
          },
          "dependencies": {
            "runtime": [
              "express",
              "cors",
              "helmet",
              "cookie-parser",
              "pino-pretty",
              "pino",
              "dotenv-flow",
              "cross-env",
              "source-map-support",
              "zod",
              "@prisma/client@6"
            ],
            "dev": [
              "typescript",
              "tsx",
              "prisma@6",
              "tsc-alias",
              "@types/node",
              "@types/express",
              "morgan",
              "@types/cors",
              "@types/morgan",
              "@types/cookie-parser",
              "prettier",
              "@commitlint/cli",
              "@commitlint/config-conventional",
              "@types/source-map-support",
              "lint-staged"
            ]
          },
          "env": [
            "LOG_LEVEL",
            "NODE_ENV",
            "PORT",
            "CORS_ORIGIN",
            "DATABASE_URL"
          ]
        }
      }
    }
  }
}

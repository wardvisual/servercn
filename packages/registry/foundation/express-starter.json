{
  "$schema": "https://servercn.vercel.app/schema/foundation.registry.json",
  "slug": "express-starter",
  "runtimes": {
    "node": {
      "frameworks": {
        "express": {
          "templates": {
            "mvc": "express-starter/mvc",
            "feature": "express-starter/feature"
          },
          "dependencies": {
            "runtime": [
              "express",
              "cors",
              "dotenv-flow",
              "cross-env",
              "helmet",
              "cookie-parser",
              "pino",
              "pino-pretty",
              "source-map-support",
              "zod",
              "swagger-autogen",
              "swagger-ui-express"
            ],
            "dev": [
              "@types/express",
              "morgan",
              "@types/cors",
              "@types/morgan",
              "@types/cookie-parser",
              "@types/source-map-support",
              "@types/swagger-ui-express"
            ]
          },
          "env": ["LOG_LEVEL", "NODE_ENV", "PORT", "CORS_ORIGIN"]
        }
      }
    }
  }
}
